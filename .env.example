# ── Demo Mode (mock backend) ──────────────────────────────────────────────────
# Set to "/" to use the local Next.js API mock routes (no real backend needed).
# Set to "https://api.ghostswap.finance/" to use the real backend (if live).
NEXT_PUBLIC_AWS_URL="/"

# WalletConnect v2 project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=""

# ── Optional / legacy keys (not required for demo mode) ──────────────────────
NEXT_PUBLIC_TRANSAK_API_KEY=""
NEXT_PUBLIC_TRANSAK_ENVIRONMENT=""
NEXT_PUBLIC_ARCHER_API_KEY=""
NEXT_PUBLIC_CLOUDINARY_URL=""
NEXT_PUBLIC_GOOGLE_ANALYTICS=""
NEXT_PUBLIC_INTO_THE_BLOCK_API_KEY=""
NEXT_PUBLIC_SENTRY_DSN=""
REDIS_URL=""